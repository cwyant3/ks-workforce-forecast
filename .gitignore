__pycache__/
*.pyc
*.pyo
.env
.env.*
*.egg-info/
.DS_Store
Thumbs.db
.streamlit/secrets.toml

# API/download caches (regenerable; may contain large binaries)
data/qcew_cache/
data/laus_cache/
data/ipeds_cache/
data/lodes_cache/
data/oes_cache/
data/cbp_cache/
data/jolts_cache/
data/kdol_cache/
data/ksde_cache/
data/ssa_cache/
data/bls_proj_cache/
data/pc_cache/

# State ACS caches are regenerable — never tracked (dashboard reads outputs, not caches).
data/acs_cache/acs5_*_s01.parquet
data/acs_cache/acs5_*_s08.parquet
data/acs_cache/acs5_*_s15.parquet
data/acs_cache/acs5_*_s27.parquet
data/acs_cache/acs5_*_s29.parquet
data/acs_cache/acs5_*_s31.parquet
data/acs_cache/acs5_*_s40.parquet

# Test/benchmark states (AL 01, HI 15, MN 27) — outputs NOT tracked.
data/outputs/acs_combined_s01.parquet
data/outputs/projections_s01.parquet
data/outputs/county_summary_s01.csv
data/outputs/state_projection_s01.parquet
data/outputs/participation_s01.parquet
data/outputs/projections_effective_s01.parquet
# The bloc (KS s20, CO s08, NE s31, MO s29, OK s40) IS tracked below the cache
# line, so the deployed dashboard loads them like Kansas. Only the 6 base-build
# files were ever ignored; the parity layers (LAUS/LODES/CBP/OES/IPEDS/SSA/PC…)
# were already trackable.
data/outputs/acs_combined_s15.parquet
data/outputs/acs_combined_s27.parquet
data/outputs/projections_s15.parquet
data/outputs/projections_s27.parquet
data/outputs/county_summary_s15.csv
data/outputs/county_summary_s27.csv
data/outputs/state_projection_s15.parquet
data/outputs/state_projection_s27.parquet
data/outputs/participation_s15.parquet
data/outputs/participation_s27.parquet
data/outputs/projections_effective_s15.parquet
data/outputs/projections_effective_s27.parquet

# User-dropped raw data files at data/ root (KDOL Telerik exports etc.)
# These are large HTML-as-.xls reports; parsed outputs live in data/outputs/
data/*.xls
data/*.xlsx
data/*.csv

# Per-run refresh logs (transient; regenerated on each --all)
data/outputs/_refresh_log_*.txt
